# Copy to .env (do not commit .env — it is gitignored)

# Fake recipes, no network (good for UI testing without a key)
# VITE_USE_MOCK_AI=true

# Your provider key — baked in at build time (required for real AI unless mock mode).
# For GitHub Pages: set this when you run `npm run build` locally, or set the same
# name as a secret in GitHub Actions and pass it into the build step.
# VITE_AI_API_KEY=

# Legacy name (still works)
# VITE_ANTHROPIC_API_KEY=
