# Copy to .env (do not commit .env — it is gitignored)

# Fake recipes, no network (good for UI testing without a key)
# VITE_USE_MOCK_AI=true

# OpenAI API key — baked in at build time (required for real AI unless mock mode).
# Use either name (same sk-... value is fine):
# VITE_OPENAI_API_KEY=
# VITE_AI_API_KEY=

# Optional: model id (default gpt-4o-mini)
# VITE_OPENAI_MODEL=gpt-4o-mini
